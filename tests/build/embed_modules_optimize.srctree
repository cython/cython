# mode: run
# tag: embed

# standalone
PYTHON cythonize_embed.py a.pyx b.pyx
CYTHON --embed --embed-modules a,b main_module.pyx
UNSET CFLAGS -DCYTHON_REFNANNY
PYTHON build.py main_module main_module.c a.c b.c
PYTHON run.py main_module

# With auto_cpdef=True (uses function pointer import)
PYTHON cythonize_embed.py -f -X auto_cpdef=True a.pyx b.pyx
PYTHON check_codegen.py auto_cpdef a.c
CYTHON --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.c a.c b.c
PYTHON run.py main_module

# CPP auto_cpdef=True (uses function pointer import)
PYTHON cythonize_embed.py -+ -f -X auto_cpdef=True a.pyx b.pyx
PYTHON check_codegen.py auto_cpdef a.cpp
CYTHON -+ --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.cpp a.cpp b.cpp
PYTHON run.py main_module

# With lto=True (uses direct function call)
PYTHON cythonize_embed.py -f -X auto_cpdef=True -X lto=True a.pyx b.pyx
PYTHON check_codegen.py lto a.c
CYTHON --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.c a.c b.c
PYTHON run.py main_module

# CPP With lto=True (uses direct function call)
PYTHON cythonize_embed.py -+ -f -X auto_cpdef=True -X lto=True a.pyx b.pyx
PYTHON check_codegen.py lto a.cpp
CYTHON -+ --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.cpp a.cpp b.cpp
PYTHON run.py main_module

################### cythonize_embed.py ########################

import sys
import Cython.Compiler.Options
Cython.Compiler.Options.cimport_from_pyx = True

from Cython.Build.Cythonize import main
sys.argv[0] = 'cythonize.py'
main()

################### check_codegen.py ########################

import sys
import os

mode = sys.argv[1]
a_c_path = sys.argv[2]
with open(a_c_path, 'r') as f:
    a_c_content = f.read()

if mode == 'auto_cpdef':
    assert "static int (*__pyx_f_1b_1B_4prop___get__)(struct __pyx_obj_1b_B *);" in a_c_content
    assert "__pyx_f_1b_1B_4prop___get__(((struct __pyx_obj_1b_B *)__pyx_v_self))" in a_c_content
    print("OK: auto_cpdef mode uses function pointer import")

elif mode == 'lto':
    assert "int __pyx_f_1b_1B_4prop___get__(struct __pyx_obj_1b_B *);" in a_c_content
    assert "__pyx_f_1b_1B_4prop___get__(((struct __pyx_obj_1b_B *)__pyx_v_self))" in a_c_content
    print("OK: LTO mode uses direct function call")

else:
    print(f"Unknown mode: {mode}")
    sys.exit(1)

################### build.py ########################

import os
import setuptools
import sys
import sysconfig
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor

IS_WINDOWS = sys.platform == 'win32'

if IS_WINDOWS:
    import distutils.msvc9compiler as setuptools_msvc  # from setuptools
    ccompiler = setuptools_msvc.MSVCCompiler()
    ccompiler.initialize()
    compiler_exe = ccompiler.cc
    linker_exe = ccompiler.linker_exe
else:
    import distutils.unixccompiler as setuptools_cc  # from setuptools
    ccompiler = setuptools_cc.UnixCCompiler()
    compiler_exe = ccompiler.compiler
    linker_exe = ccompiler.linker_exe


def get_config_var(name, default='', *, _get_config_var=sysconfig.get_config_vars().get):
    return _get_config_var(name, default)


INCDIR = sysconfig.get_path('include')
LIBDIR1 = get_config_var('LIBDIR')
LIBDIR2 = get_config_var('LIBPL')
PYLIB_DIR = get_config_var("installed_platbase")
PYLIB = get_config_var('LIBRARY')
PYLIB_DYN = get_config_var('LDLIBRARY')

if sys.platform == 'darwin':
    PYLIB_DYN = f'python{sys.version_info[0]}.{sys.version_info[1]}'
elif PYLIB_DYN == PYLIB:
    # no shared library
    PYLIB_DYN = ''
elif PYLIB_DYN:
    # 'lib(XYZ).so' -> XYZ
    PYLIB_DYN = os.path.splitext(PYLIB_DYN)[0]
    if PYLIB_DYN.startswith('lib'):
        PYLIB_DYN = PYLIB_DYN[3:]

CFLAGS = get_config_var('CFLAGS') + ' ' + os.environ.get('CFLAGS', '')

OBJ_EXT = ccompiler.obj_extension
LIBS = get_config_var('LIBS')
SYSLIBS = get_config_var('SYSLIBS')
EXE_EXT = get_config_var('EXE')


def compile(source_file):
    ccompiler.compile(
        sources=[source_file],
        include_dirs=[INCDIR],
        extra_postargs=CFLAGS.split(),
    )


def link_exe(objects, app_name):
    library_dirs = [
        libdir for libdir in
        [LIBDIR1, LIBDIR2, os.path.join(PYLIB_DIR, "libs")]
        if libdir and os.path.isdir(libdir)
    ]
    if PYLIB_DYN:
        libraries = [PYLIB_DYN]
    elif PYLIB:
        objects = [*objects, os.path.join(LIBDIR1, PYLIB)]
        libraries = [
            lib[2:] if lib.startswith('-l') else lib
            for lib in [*LIBS.split(), *SYSLIBS.split()]
        ]
    else:
        libraries = []

    ccompiler.link(
        ccompiler.EXECUTABLE,
        objects,
        output_filename=app_name + EXE_EXT,
        libraries=libraries,
        library_dirs=library_dirs,
        runtime_library_dirs=[PYLIB_DIR],
    )


def main(args):
    app_name, *c_files = args
    c_base_names = [Path(filename).stem for filename in c_files]

    print("CFLAGS:", CFLAGS)
    print(f"PYLIBS: {PYLIB!r} {PYLIB_DYN!r}")
    print(f"LINK: {LIBDIR1!r} {LIBDIR2!r}")
    print("LIBDIR1:", os.listdir(LIBDIR1))

    compile_commands = c_files
    for command in compile_commands:
        print("CC:", command)

    with ThreadPoolExecutor() as pool:
        for _ in pool.map(compile, compile_commands):
            pass

    link_exe(
        [filename + OBJ_EXT for filename in c_base_names],
        app_name=app_name,
    )


if __name__ == '__main__':
    main(sys.argv[1:])


################### run.py ########################

import os
import sys
from subprocess import run
from sysconfig import get_config_var

EXE_EXT = get_config_var('EXE')
PYLIB_DIR = get_config_var("installed_platbase")

PATH = os.environ.get('PATH', '')
sep = os.pathsep
os.environ.update(PATH=f".{sep}{PYLIB_DIR}{sep}{PATH}")

result = run([os.path.abspath(sys.argv[1] + EXE_EXT)], check=True)

################# main_module.pyx ####################

import a
import b

assert __name__ == '__main__'

t: A = a.A()
u: B = b.B()

# Test class methods
t.mtd_cpdef()
u.mtd()

# Test properties
t.prop = 2  # test setter (prop getter adds 1)
t.prop_cenum = b.Color.RED  # test setter
t.prop_obj = b.B()  # test setter
t.prop_tuple = (3, 4)  # test setter
t.prop_bool = True  # test setter
assert t.prop == 3
assert t.prop_cenum == b.Color.RED
assert t.prop_obj.prop == 2
assert t.prop_tuple == (1, 2)
assert t.prop_bool is True

assert u.prop == 2

# Test ccall functions
assert a.func_in_a() == 9
assert b.func_in_b() == 9

print("DONE")

################# a.pyx ####################

from b import B, func_in_b, Color
from b cimport B, func_in_b, Color
from cython import ccall, cclass, int, bint as bool

cdef bint _helper = True

@cclass
class TestBugDescrGet:
    """Class that triggers tp_descr_get generation with mixed return types.

    With auto_cpdef=True:
    - prop_obj and prop_int are cpdef-converted (add __get__ to class scope)
    - prop_bool is NOT cpdef-convertible (has closure), so all_overridable=False
    - tp_descr_get is generated using the last cpdef property's getter (prop_int)
    - But prop_int returns int, not PyObject*, causing type mismatch
    """
    @property
    def prop_obj(self) -> object:  # PyObject* - first cpdef property
        return None

    @property
    def prop_int(self) -> int:     # C int - last cpdef property
        return 42

    @property
    def prop_bool(self) -> bool:  # NOT cpdef (closure via lambda)
        return (lambda: _helper)()

@ccall
def func_in_a():
    t: A = A()
    t.prop = 2  # test setter (prop getter adds 1)
    t.prop_cenum = Color.RED  # test setter
    t.prop_obj = B()  # test setter
    t.prop_tuple = (3, 4)  # test setter
    t.prop_bool = True  # test setter
    assert t.prop == 3
    assert t.prop_cenum == Color.RED
    assert t.prop_obj.prop == 2
    assert t.prop_tuple == (1, 2)
    assert t.prop_bool is True

    # Test tp_descr_get generation with mixed return types
    bug_obj = TestBugDescrGet()
    assert bug_obj.prop_obj is None
    assert bug_obj.prop_int == 42
    assert bug_obj.prop_bool is True

    return func_in_b()

@cclass
class A(B):

    _prop_bool: bool

    def __init__(self) -> None:
        self._prop_bool = False

    @ccall
    def mtd_cpdef(self):
        super().mtd()

    @property
    def prop(self) -> int:
        return super().prop + 1

    @prop.setter
    def prop(self, int val) -> None:
        B.prop.__set__(self, val)

    @property
    def prop_bool(self) -> bool:
        return self._prop_bool

    @prop_bool.setter
    def prop_bool(self, v: bool) -> bool:
        self._prop_bool = v

    @property
    def prop_cenum(self) -> Color:
        return Color.RED

    @prop_cenum.setter
    def prop_cenum(self, Color val) -> None:
        pass  # no-op for testing

    @property
    def prop_obj(self) -> B:
        return B()

    @prop_obj.setter
    def prop_obj(self, val: B) -> None:
        pass  # no-op for testing

    @property
    def prop_tuple(self) -> tuple[int, int]:
        return (1, 2)

    @prop_tuple.setter
    def prop_tuple(self, val: tuple[int, int]) -> None:
        pass  # no-op for testing

################# b.pyx ####################

from enum import Enum
from cython import cclass, ccall, int

@cclass
class Color(Enum):
    RED = 1

@ccall
def func_in_b():
    B().mtd()
    return 9

@cclass
class B:

    __prop_int: int

    def __init__(self) -> None:
        self.__prop_int = 2

    @ccall
    def mtd(self):
        pass

    @property
    def prop(self) -> int:
        return self.__prop_int

    @prop.setter
    def prop(self, int val) -> None:
        self.__prop_int = val
