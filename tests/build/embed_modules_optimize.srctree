# mode: run
# tag: embed

# standalone
PYTHON cythonize_embed.py a.pyx b.pyx
PYTHON check_codegen.py default a.c
CYTHON --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.c a.c b.c
PYTHON run.py main_module

# With auto_cpdef=True (uses function pointer import)
PYTHON cythonize_embed.py -f -X auto_cpdef=True a.pyx b.pyx
PYTHON check_codegen.py auto_cpdef a.c
CYTHON --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.c a.c b.c
PYTHON run.py main_module

# CPP auto_cpdef=True (uses function pointer import)
PYTHON cythonize_embed.py -+ -f -X auto_cpdef=True a.pyx b.pyx
PYTHON check_codegen.py auto_cpdef a.cpp
CYTHON -+ --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.cpp a.cpp b.cpp
PYTHON run.py main_module

# With lto=True (uses direct function call)
PYTHON cythonize_embed.py -f -X auto_cpdef=True -X lto=True a.pyx b.pyx
PYTHON check_codegen.py lto a.c
CYTHON --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.c a.c b.c
PYTHON run.py main_module

# With lto=True (uses direct function call without python subclassing support)
PYTHON cythonize_embed.py -f -X auto_cpdef=True -X lto=True -X python_subclassing=False a.pyx b.pyx
PYTHON check_codegen.py lto a.c
CYTHON --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.c a.c b.c
PYTHON run.py main_module

# CPP With lto=True (uses direct function call)
PYTHON cythonize_embed.py -+ -f -X auto_cpdef=True -X lto=True a.pyx b.pyx
PYTHON check_codegen.py lto a.cpp
CYTHON -+ --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.cpp a.cpp b.cpp
PYTHON run.py main_module

# CPP With lto=True (uses direct function call without python subclassing support)
PYTHON cythonize_embed.py -+ -f -X auto_cpdef=True -X lto=True -X python_subclassing=False a.pyx b.pyx
PYTHON check_codegen.py lto_no_python_subclassing a.cpp
CYTHON -+ --embed --embed-modules a,b main_module.pyx
PYTHON build.py main_module main_module.cpp a.cpp b.cpp
PYTHON run.py main_module

################### cythonize_embed.py ########################

import sys
import Cython.Compiler.Options
Cython.Compiler.Options.cimport_from_pyx = True

from Cython.Build.Cythonize import main
sys.argv[0] = 'cythonize.py'
sys.argv.append('-X')
sys.argv.append('infer_types=True')
main()

################### check_codegen.py ########################

import sys
import os

mode = sys.argv[1]
a_c_path = sys.argv[2]
with open(a_c_path, 'r') as f:
    a_c_content = f.read()

if mode == 'default':
    assert "__Pyx_PyObject_GetAttrStr(((PyObject *)__pyx_v_item), __pyx_mstate_global->__pyx_n_u_prop);" in a_c_content
    # Python property access -> temp inferred as a Python object, not C int.
    assert "int __pyx_v_temp;" not in a_c_content, (
        "Expected temp to be a Python object in default mode (Python property access)")
    print("OK: default mode uses Python GetAttrStr call")

elif mode == 'auto_cpdef':
    assert "static int (*__pyx_f_1b_1B_4prop___get__)(struct __pyx_obj_1b_B *);" in a_c_content
    assert "->__pyx_f_1b_1B_4prop___get__(((struct __pyx_obj_1b_B *)" in a_c_content
    assert "__Pyx_PyObject_GetAttrStr(((PyObject *)__pyx_v_item), __pyx_mstate_global->__pyx_n_u_prop);" not in a_c_content, "Expected no Python GetAttrStr call"
    assert "__Pyx_PyObject_FastCallMethod((PyObject*)__pyx_mstate_global->__pyx_n_u_init," not in a_c_content, "Expected no call to DerivedWithCtorOverride constructor skipping python"
    # Cross-module constructor optimization: BWithOptInit(5) and BWithOptInit(5, 2.5)
    # must be split into tp_new + vtable __init__ call, not a Python type() call.
    # The vtable slot for __init__ is accessed via the exported vtable pointer.
    assert "__pyx_vtabptr_1b_BWithOptInit->__pyx___init__" in a_c_content, (
        "Expected vtable __init__ dispatch for BWithOptInit cross-module constructor")
    assert "__pyx_opt_args_1b_12BWithOptInit___init__" in a_c_content, (
        "Expected opt_args struct for BWithOptInit.__init__ optional-arg call in auto_cpdef mode")
    assert '__Pyx_RaiseUnboundLocalError("bopt2")' not in a_c_content, (
        "Expected no redundant unbound-local check for bopt2 after tp_new null-check")
    assert "float y;" in a_c_content, (
        "Expected DataClass.__init__ opt_args struct to use C float for 'y', not PyObject*")
    # Keyword-arg constructor DataClass(x=1) must also be optimised (tp_new + vtable __init__)
    assert "__pyx_vtabptr_1b_DataClass->__pyx___init__" in a_c_content, (
        "Expected vtable __init__ dispatch for DataClass(x=1) keyword-arg constructor call")
    # cpdef classmethod: vtable slot call (not Python GetAttrStr) in calling module
    assert "__pyx_vtabptr_1b_B->class_tag" in a_c_content, (
        "Expected vtable slot call for cpdef classmethod in auto_cpdef mode")
    # cproperty getter returns C int, so `temp = t.prop + t.prop` infers temp as int.
    assert "int __pyx_v_temp;" in a_c_content, (
        "Expected temp inferred as C int from cproperty getter return type")
    print("OK: auto_cpdef mode")

elif mode == 'lto':
    assert "int __pyx_f_1b_1B_4prop___get__(struct __pyx_obj_1b_B *);" in a_c_content
    assert "__pyx_vtabptr_1b_B->__pyx_f_1b_1B_4prop___get__" not in a_c_content, "Expected direct call to 'super().method', not vtable dispatch"
    assert "__Pyx_PyObject_GetAttrStr(((PyObject *)__pyx_v_item), __pyx_mstate_global->__pyx_n_u_prop);" not in a_c_content
    assert "__pyx_vtab)->__pyx_f_1b_8Derived3_4prop___get__(" not in a_c_content, "Expected direct call to final method, not vtable dispatch"
    assert "__Pyx_PyObject_FastCallMethod((PyObject*)__pyx_mstate_global->__pyx_n_u_init," not in a_c_content, "Expected no call to DerivedWithCtorOverride constructor skipping python"
    assert "__pyx_vtabptr_1b_BWithOptInit->__pyx___init__" in a_c_content, (
        "Expected vtable __init__ dispatch for BWithOptInit cross-module constructor in lto mode")
    assert "__pyx_opt_args_1b_12BWithOptInit___init__" in a_c_content, (
        "Expected opt_args struct for BWithOptInit.__init__ optional-arg call in lto mode")
    assert '__Pyx_RaiseUnboundLocalError("bopt2")' not in a_c_content, (
        "Expected no redundant unbound-local check for bopt2 after tp_new null-check")
    assert "float y;" in a_c_content, (
        "Expected DataClass.__init__ opt_args struct to use C float for 'y', not PyObject*")
    assert "int __pyx_v_temp;" in a_c_content, (
        "Expected temp inferred as C int from cproperty getter return type")
    print("OK: LTO mode")

elif mode == 'lto_no_python_subclassing':
    # Same LTO checks as 'lto', plus verify that python_subclassing=False removes
    # the __pyx_skip_dispatch / OverrideCheckNode dispatch block from cpdef methods.
    assert "int __pyx_f_1b_1B_4prop___get__(struct __pyx_obj_1b_B *);" in a_c_content
    assert "__pyx_vtabptr_1b_B->__pyx_f_1b_1B_4prop___get__" not in a_c_content, "Expected direct call to 'super().method', not vtable dispatch"
    assert "__Pyx_PyObject_GetAttrStr(((PyObject *)__pyx_v_item), __pyx_mstate_global->__pyx_n_u_prop);" not in a_c_content
    assert "__pyx_vtab)->__pyx_f_1b_8Derived3_4prop___get__(" not in a_c_content, "Expected direct call to final method, not vtable dispatch"
    assert "__Pyx_PyObject_FastCallMethod((PyObject*)__pyx_mstate_global->__pyx_n_u_init," not in a_c_content, "Expected no call to DerivedWithCtorOverride constructor skipping python"
    assert "__pyx_vtabptr_1b_BWithOptInit->__pyx___init__" in a_c_content, (
        "Expected vtable __init__ dispatch for BWithOptInit cross-module constructor in lto+no_ps mode")
    assert "__pyx_opt_args_1b_12BWithOptInit___init__" in a_c_content, (
        "Expected opt_args struct for BWithOptInit.__init__ optional-arg call in lto+no_ps mode")
    assert '__Pyx_RaiseUnboundLocalError("bopt2")' not in a_c_content, (
        "Expected no redundant unbound-local check for bopt2 after tp_new null-check")
    assert "float y;" in a_c_content, (
        "Expected DataClass.__init__ opt_args struct to use C float for 'y', not PyObject*")
    # python_subclassing=False: cpdef/ccall methods must NOT contain the override-check block.
    # The __pyx_skip_dispatch *parameter* stays (vtable ABI), but it must be CYTHON_UNUSED
    # and the "Check if overridden in Python" block must be absent.
    assert "CYTHON_UNUSED int __pyx_skip_dispatch" in a_c_content, (
        "Expected CYTHON_UNUSED skip_dispatch parameter (vtable ABI) in cpdef methods")
    # The dispatch block is anchored by the comment Cython always emits just before it.
    assert "/* Check if overridden in Python */" not in a_c_content, (
        "Expected no 'Check if overridden in Python' dispatch block with python_subclassing=False")
    assert "int __pyx_v_temp;" in a_c_content, (
        "Expected temp inferred as C int from cproperty getter return type")
    print("OK: LTO + python_subclassing=False mode")

else:
    print(f"Unknown mode: {mode}")
    sys.exit(1)

################### build.py ########################

import os
import setuptools
import sys
import sysconfig
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor

IS_WINDOWS = sys.platform == 'win32'

if IS_WINDOWS:
    import distutils.msvc9compiler as setuptools_msvc  # from setuptools
    ccompiler = setuptools_msvc.MSVCCompiler()
    ccompiler.initialize()
    compiler_exe = ccompiler.cc
    linker_exe = ccompiler.linker_exe
else:
    import distutils.unixccompiler as setuptools_cc  # from setuptools
    ccompiler = setuptools_cc.UnixCCompiler()
    compiler_exe = ccompiler.compiler
    linker_exe = ccompiler.linker_exe


def get_config_var(name, default='', *, _get_config_var=sysconfig.get_config_vars().get):
    return _get_config_var(name, default)


INCDIR = sysconfig.get_path('include')
LIBDIR1 = get_config_var('LIBDIR')
LIBDIR2 = get_config_var('LIBPL')
PYLIB_DIR = get_config_var("installed_platbase")
PYLIB = get_config_var('LIBRARY')
PYLIB_DYN = get_config_var('LDLIBRARY')

if sys.platform == 'darwin':
    PYLIB_DYN = f'python{sys.version_info[0]}.{sys.version_info[1]}'
elif PYLIB_DYN == PYLIB:
    # no shared library
    PYLIB_DYN = ''
elif PYLIB_DYN:
    # 'lib(XYZ).so' -> XYZ
    PYLIB_DYN = os.path.splitext(PYLIB_DYN)[0]
    if PYLIB_DYN.startswith('lib'):
        PYLIB_DYN = PYLIB_DYN[3:]

CFLAGS = get_config_var('CFLAGS') + ' ' + os.environ.get('CFLAGS', '')

OBJ_EXT = ccompiler.obj_extension
LIBS = get_config_var('LIBS')
SYSLIBS = get_config_var('SYSLIBS')
EXE_EXT = get_config_var('EXE')


def compile(source_file):
    ccompiler.compile(
        sources=[source_file],
        include_dirs=[INCDIR],
        extra_postargs=CFLAGS.split(),
    )


def link_exe(objects, app_name):
    library_dirs = [
        libdir for libdir in
        [LIBDIR1, LIBDIR2, os.path.join(PYLIB_DIR, "libs")]
        if libdir and os.path.isdir(libdir)
    ]
    if PYLIB_DYN:
        libraries = [PYLIB_DYN]
    elif PYLIB:
        objects = [*objects, os.path.join(LIBDIR1, PYLIB)]
        libraries = [
            lib[2:] if lib.startswith('-l') else lib
            for lib in [*LIBS.split(), *SYSLIBS.split()]
        ]
    else:
        libraries = []

    ccompiler.link(
        ccompiler.EXECUTABLE,
        objects,
        output_filename=app_name + EXE_EXT,
        libraries=libraries,
        library_dirs=library_dirs,
        runtime_library_dirs=[PYLIB_DIR],
    )


def main(args):
    app_name, *c_files = args
    c_base_names = [Path(filename).stem for filename in c_files]

    print("CFLAGS:", CFLAGS)
    print(f"PYLIBS: {PYLIB!r} {PYLIB_DYN!r}")
    print(f"LINK: {LIBDIR1!r} {LIBDIR2!r}")
    print("LIBDIR1:", os.listdir(LIBDIR1))

    compile_commands = c_files
    for command in compile_commands:
        print("CC:", command)

    with ThreadPoolExecutor() as pool:
        for _ in pool.map(compile, compile_commands):
            pass

    link_exe(
        [filename + OBJ_EXT for filename in c_base_names],
        app_name=app_name,
    )


if __name__ == '__main__':
    main(sys.argv[1:])


################### run.py ########################

import os
import sys
from subprocess import run
from sysconfig import get_config_var

EXE_EXT = get_config_var('EXE')
PYLIB_DIR = get_config_var("installed_platbase")

PATH = os.environ.get('PATH', '')
sep = os.pathsep
os.environ.update(PATH=f".{sep}{PYLIB_DIR}{sep}{PATH}")

result = run([os.path.abspath(sys.argv[1] + EXE_EXT)], check=True)

################# main_module.pyx ####################

import a
import b

assert __name__ == '__main__'

t: A = a.A()
tt: B = t
u: B = b.B()

# Test class methods
t.mtd_cpdef()
u.mtd()

# Test properties
t.prop = 2  # test setter (prop getter adds 1)
t.prop_cenum = b.Color.RED  # test setter
t.prop_obj = b.B()  # test setter
t.prop_tuple = (3, 4)  # test setter
t.prop_bool = True  # test setter
assert t.prop == 3
assert t.prop_cenum == b.Color.RED
assert t.prop_obj.prop == 2
assert t.prop_tuple == (1, 2)
assert t.prop_bool is True
assert t.prop_closure == 14
# vtable dispatch: tt is A() typed as B, should correctly resolve to A's override
assert tt.prop == 3

assert u.prop == 2

t2 = a.A2()
try:
    t2.prop = 2
    assert False, "Expected ValueError from A2.prop setter, but no exception was raised"
except ValueError as e:
    assert str(e) == "Test raise in setter", f"Expected ValueError with message 'Test raise in setter', got {e}"

try:
    assert t2.prop, "Expected ValueError from A2.prop getter, but no exception was raised"
    assert False, "Expected ValueError from A2.prop setter, but no exception was raised"
except ValueError as e:
    assert str(e) == "Test raise in setter", f"Expected ValueError with message 'Test raise in setter', got {e}"

try:
    a.DerivedWithCtorRaise(1)
    assert False, "Expected ValueError from DerivedWithCtorRaise constructor, but no exception was raised"
except ValueError as e:
    assert str(e) == "Test raise in constructor", f"Expected ValueError with message 'Test raise in constructor', got {e}"


# Test cpdef classmethod
assert b.B.class_tag() == 'B'
assert u.class_tag() == 'B'

# Test ccall functions
assert a.func_in_a() == 9
assert b.func_in_b() == 9

print("DONE")

################# a.pyx ####################

from b import B, Derived, Derived2, Derived3, IBase, BWithOptInit, func_in_b, func_with_parameter, Color, DataClass
from b cimport B, Derived, Derived2, Derived3, IBase, BWithOptInit, func_in_b, func_with_parameter, Color, DataClass
from cython import ccall, cclass, int, bint as bool, typeof

cdef bint _helper = True

@cclass
class TestBugDescrGet:
    """Class that triggers tp_descr_get generation with mixed return types.

    With auto_cpdef=True:
    - prop_obj and prop_int are cpdef-converted (add __get__ to class scope)
    - prop_bool is NOT cpdef-convertible (has closure), so all_overridable=False
    - tp_descr_get is generated using the last cpdef property's getter (prop_int)
    - But prop_int returns int, not PyObject*, causing type mismatch
    """
    @property
    def prop_obj(self) -> object:  # PyObject* - first cpdef property
        return None

    @property
    def prop_int(self) -> int:     # C int - last cpdef property
        return 42

    @property
    def prop_bool(self) -> bool:  # NOT cpdef (closure via lambda)
        return (lambda: _helper)()

@ccall
def func_in_a():
    t: A = A()
    tt: B = t
    t.prop = 2  # test setter (prop getter adds 1)
    t.prop_cenum = Color.RED  # test setter
    t.prop_obj = B()  # test setter
    t.prop_tuple = (3, 4)  # test setter
    t.prop_bool = True  # test setter
    assert t.prop == 3
    assert t.prop_cenum == Color.RED
    assert t.prop_obj.prop == 2
    assert t.prop_tuple == (1, 2)
    assert t.prop_bool is True
    assert t.prop_closure == 14
    # vtable dispatch through B* reference to A() instance
    assert tt.prop == 3

    temp = t.prop + t.prop
    # In optimized modes (auto_cpdef/lto) t.prop is a cproperty returning a C int,
    # so type inference resolves temp to int. In default mode t.prop is a Python
    # property and temp stays a Python object. (Codegen checked in check_codegen.py.)
    assert typeof(temp) in ('int', 'Python object'), typeof(temp)

    t2 = A2()
    try:
        t2.prop = 2
        assert False, "Expected ValueError from A2.prop setter, but no exception was raised"
    except ValueError as e:
        assert str(e) == "Test raise in setter", f"Expected ValueError with message 'Test raise in setter', got {e}"

    try:
        assert t2.prop, "Expected ValueError from A2.prop getter, but no exception was raised"
        assert False, "Expected ValueError from A2.prop setter, but no exception was raised"
    except ValueError as e:
        assert str(e) == "Test raise in setter", f"Expected ValueError with message 'Test raise in setter', got {e}"

    try:
        DerivedWithCtorRaise(1)
        assert False, "Expected ValueError from DerivedWithCtorRaise constructor, but no exception was raised"
    except ValueError as e:
        assert str(e) == "Test raise in constructor", f"Expected ValueError with message 'Test raise in constructor', got {e}"

    # Test tp_descr_get generation with mixed return types
    bug_obj = TestBugDescrGet()
    assert bug_obj.prop_obj is None
    assert bug_obj.prop_int == 42
    assert bug_obj.prop_bool is True

    assert func_with_parameter(t) == 3  # passing A through parameter typed as A
    assert func_with_parameter(tt) == 3  # passing A through parameter typed as B

    # final prop should invoke directly, not through vtable
    assert Derived3().prop == 100, "Expected Derived3.prop to be 100"

    # test that constructor overrides work and don't interfere with property getters
    dw: DerivedWithCtorOverride
    dw = DerivedWithCtorOverride(1, 2.0, "test")
    assert dw._prop == 3, f"Expected DerivedWithCtorOverride._prop to be 3, got {dw._prop}"
    dw = DerivedWithCtorOverride.__new__(DerivedWithCtorOverride)
    DerivedWithCtorOverride.__init__(dw, 1, 2.0, "test")
    assert dw._prop == 3, f"Expected DerivedWithCtorOverride._prop to be 3, got {dw._prop}"
    dw2: DerivedWithCtorOverrideClosure
    dw2 = DerivedWithCtorOverrideClosure(2, 3.0, "test")
    assert dw2._prop == 8, f"Expected DerivedWithCtorOverrideClosure._prop to be 8, got {dw2._prop}"
    dw2 = DerivedWithCtorOverrideClosure.__new__(DerivedWithCtorOverrideClosure)
    #DerivedWithCtorOverrideClosure.__init__(dw2, 3, 3.0, "test")  # commented because it would require python call which check_codegen check against
    #assert dw2._prop == 9, f"Expected DerivedWithCtorOverrideClosure._prop to be 9, got {dw2._prop}"
    dw3: DerivedWithCtor
    dw3 = DerivedWithCtor(4, 5.0)
    assert dw3._prop == 4, f"Expected DerivedWithCtor._prop to be 4, got {dw3._prop}"
    dw3 = DerivedWithCtor.__new__(DerivedWithCtor)
    DerivedWithCtor.__init__(dw3, 4, 5.0)
    assert dw3._prop == 4, f"Expected DerivedWithCtor._prop to be 4, got {dw3._prop}"

    func_with_for_loop()

    # Test cross-module constructor with optional args (required-only call)
    bopt: BWithOptInit = BWithOptInit(5)
    assert bopt.x == 5, f"Expected BWithOptInit(5).x == 5, got {bopt.x}"
    assert bopt.y == 1.5, f"Expected BWithOptInit(5).y == 1.5, got {bopt.y}"
    # Test cross-module constructor with optional args (explicit optional call)
    bopt2: BWithOptInit = BWithOptInit(5, 2.5)
    assert bopt2.x == 5, f"Expected BWithOptInit(5,2.5).x == 5, got {bopt2.x}"
    assert bopt2.y == 2.5, f"Expected BWithOptInit(5,2.5).y == 2.5, got {bopt2.y}"
    # Test constructor in return and argument expression contexts
    _bopt3: BWithOptInit = _make_bopt(7)
    assert _bopt3.x == 7, f"Expected _make_bopt(7).x == 7, got {_bopt3.x}"
    assert _take_bopt(BWithOptInit(9)) == 9, "Expected _take_bopt(BWithOptInit(9)) == 9"

    c = DataClass(1)
    assert c.x == 1, f"Expected DataClass(1).x == 1, got {c.x}"
    assert c.y == 2.5, f"Expected DataClass(1).y == 2.5, got {c.y}"
    c = DataClass(1, 5.0)
    assert c.x == 1, f"Expected DataClass(1).x == 1, got {c.x}"
    assert c.y == 5.0, f"Expected DataClass(1).y == 5.0, got {c.y}"
    c = DataClass(x=1)
    assert c.x == 1, f"Expected DataClass(x=1).x == 1, got {c.x}"
    assert c.y == 2.5, f"Expected DataClass(x=1).y == 2.5, got {c.y}"
    c = DataClass(x=1, y=5.0)
    assert c.x == 1, f"Expected DataClass(x=1,y=2.5).x == 1, got {c.x}"
    assert c.y == 5.0, f"Expected DataClass(1).y == 5.0, got {c.y}"
    c = DataClass.from_x(10)
    assert c.x == 10, f"Expected DataClass.from_x(10).x == 10, got {c.x}"
    assert c.y == 2.5, f"Expected DataClass.from_x(10).y == 2.5, got {c.y}"

    # Test cpdef classmethod (auto-promoted in auto_cpdef mode)
    b_inst = B()
    assert B.class_tag() == 'B', f"Expected B.class_tag() == 'B', got {B.class_tag()}"
    assert b_inst.class_tag() == 'B', f"Expected b_inst.class_tag() == 'B', got {b_inst.class_tag()}"

    # Classmethod called via a freshly-constructed no-__init__ receiver (crop-chronicles pattern:
    # Size().from_tuple(...)).  The constructor optimiser transforms Size() into a
    # TempResultFromStatNode; the ClassmethodSelfNode's inner CloneNode must be synced
    # to the new node so Py_TYPE(<new_self>) is generated instead of Py_TYPE(None).
    assert IBase().class_name() == 'IBase', f"Expected IBase().class_name() == 'IBase'"
    assert Derived().class_name() == 'Derived', f"Expected Derived().class_name() == 'Derived'"

    tp: tuple[int, float] = (5, 2.5)
    assert tp[0] == 5 and tp[1] == 2.5

    return func_in_b()

@ccall
def _make_bopt(x: int) -> BWithOptInit:
    return BWithOptInit(x)

@ccall
def _take_bopt(b: BWithOptInit) -> int:
    return b.x

def func_with_for_loop():
    items = [Derived(), Derived2()]
    item: IBase
    total: int = 0
    for item in items:
        # should call through vtable dispatch
        total = total + item.prop

    assert total == 86, f"Expected total 86, got {total}"

@cclass
class A(B):

    _prop_bool: bool

    def __init__(self) -> None:
        super().__init__()  # Can be a direct call to B.__init__ because it is known at compile time
        self._prop_bool = False

    @ccall
    def mtd_cpdef(self):
        super().mtd()

    @property
    def prop(self) -> int:
        return super().prop + 1*1

    @prop.setter
    def prop(self, int val) -> None:
        B.prop.__set__(self, val)

    @property
    def prop_bool(self) -> bool:
        return self._prop_bool

    @prop_bool.setter
    def prop_bool(self, v: bool) -> bool:
        self._prop_bool = v

    @property
    def prop_cenum(self) -> Color:
        return Color.RED

    @prop_cenum.setter
    def prop_cenum(self, Color val) -> None:
        pass  # no-op for testing

    @property
    def prop_obj(self) -> B:
        return B()

    @prop_obj.setter
    def prop_obj(self, val: B) -> None:
        pass  # no-op for testing

    @property
    def prop_tuple(self) -> tuple[int, int]:
        return (1, 2)

    @prop_tuple.setter
    def prop_tuple(self, val: tuple[int, int]) -> None:
        pass  # no-op for testing

    @property
    def prop_closure(self) -> int:
        a = [1,2,3,4]
        return sum(1+x for x in a)

    @prop_closure.setter
    def prop_closure(self, val: int) -> None:
        pass  # no-op for testing

@cclass
class A2(B):

    @property
    def prop(self) -> int:
        raise ValueError("Test raise in setter")

    @prop.setter
    def prop(self, int val) -> None:
        raise ValueError("Test raise in setter")

@cclass
class IBaseWithCtor:
    _prop: int

    def __init__(self, val: int, unused: float) -> None:
        self._prop = val

@cclass
class DerivedWithCtor(IBaseWithCtor):
    pass

@cclass
class DerivedWithCtorRaise(IBaseWithCtor):
    def __init__(self, val: int) -> None:
        raise ValueError("Test raise in constructor")

@cclass
class DerivedWithCtorOverride(DerivedWithCtor):
    def __init__(self, n: int, z: float, k: str) -> None:
        super().__init__(n, z)
        self._prop = n + 2

@cclass
class DerivedWithCtorOverrideClosure(DerivedWithCtor):
    def __init__(self, n: int, z: float, k: str) -> None:
        super().__init__(n, z)
        # this closure makes this constructor not cpdef-convertible
        # however because this is a constructor, it is not an error
        # Because the constructor are always called directly and never
        # via vtable dispatch thus it should not be treated as an override
        self._prop = (lambda: n + 2 + len(k))()

################# b.pyx ####################

from enum import Enum
from cython import cclass, ccall, final, int, float
from cython.dataclasses import dataclass

@cclass
class Color(Enum):
    RED = 1

@ccall
def func_in_b():
    B().mtd()
    return 9

@cclass
class B:

    __prop_int: int

    def __init__(self) -> None:
        self.__prop_int = 2

    @ccall
    def mtd(self):
        pass

    @property
    def prop(self) -> int:
        return self.__prop_int

    @prop.setter
    def prop(self, int val) -> None:
        self.__prop_int = val

    @property
    def prop_second(self) -> float:
        return 2.5

    @classmethod
    def class_tag(cls) -> object:
        return cls.__name__

def func_with_parameter(p: B) -> int:
    return p.prop

@cclass
class IBase:
    @property
    def prop(self) -> int:
        raise NotImplementedError()

    @classmethod
    def class_name(cls) -> object:
        return cls.__name__

@cclass
class Derived(IBase):
    @property
    def prop(self) -> int:
        return 42

@cclass
class Derived2(Derived):
    @property
    def prop(self) -> int:
        return 44

@final
@cclass
class Derived3(Derived2):
    @property
    def prop(self) -> int:
        return 100

@cclass
class BWithOptInit:
    """Class whose __init__ has an optional typed arg to test the ctor optimization."""
    x: int
    y: float

    def __init__(self, x: int, y: float = 1.5) -> None:
        self.x = x
        self.y = y


@dataclass
class DataClass:
    """Dataclass to test that dataclasses don't interfere with the optimization."""
    x: int
    y: float = 2.5

    @classmethod
    def from_x(cls, x: int) -> 'DataClass':
        return DataClass(x=x)
