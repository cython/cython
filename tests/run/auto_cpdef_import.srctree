PYTHON setup.py build_ext --inplace
PYTHON -c "import runner"

######## setup.py ########

from Cython.Build.Dependencies import cythonize
import Cython.Compiler.Options
Cython.Compiler.Options.cimport_from_pyx = True

from distutils.core import setup

setup(ext_modules=cythonize("*.pyx", compiler_directives={'auto_cpdef': True}))

######## a.pyx ########
from b import B
from b cimport B
from cython import ccall, cclass, int

@cclass
class A(B):
    @ccall
    def s(self):
        super().mtd()

    @property
    def prop(self) -> int:
        return super().prop + 1

######## b.pyx ########

from cython import cclass, ccall, int

@cclass
class B:
    @ccall
    def mtd(self):
        pass

    @property
    def prop(self) -> int:
        return 2

    @prop.setter
    def prop(self, int val):
        pass  # no-op for testing

######## runner.py ########

import a
import b

a.A().s()
print(a.A().prop)
b.B().mtd()
print(b.B().prop)
