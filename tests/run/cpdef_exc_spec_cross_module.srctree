# Cross-module exception-spec inheritance tests.
# Base in mod_a (declared in pxd), child in mod_b (inherits spec via cimport),
# consumer in mod_c that calls statically typed as BaseA.
#
# Covers:
#   - noexcept: inherited, no raise path (smoke test)
#   - except -1: inherited, raising override, static dispatch in mod_c
#   - except *:  inherited, raising override, static dispatch in mod_c
#   - Python subclass in runner.py: override raises, called through Cython wrapper

PYTHON setup.py build_ext --inplace
PYTHON runner.py

######## setup.py ########
from Cython.Build import cythonize
from distutils.core import setup

setup(ext_modules=cythonize(["mod_a.pyx", "mod_b.pyx", "mod_c.pyx"], include_path=["."]))

######## mod_a.pxd ########
# cython: language_level=3
cdef class BaseNoexcept:
    cpdef int compute(self) noexcept

cdef class BaseExcMinus1:
    cpdef int compute(self) except -1

cdef class BaseExcStar:
    cpdef int compute(self) except *

######## mod_a.pyx ########
# cython: language_level=3
cdef class BaseNoexcept:
    cpdef int compute(self) noexcept:
        return 1

cdef class BaseExcMinus1:
    cpdef int compute(self) except -1:
        return 10

cdef class BaseExcStar:
    cpdef int compute(self) except *:
        return 100

######## mod_b.pyx ########
# cython: language_level=3
# Child classes: all cpdef overrides have NO explicit exception spec.
# They must inherit the base spec from the pxd.
cimport mod_a

cdef class ChildNoexcept(mod_a.BaseNoexcept):
    cpdef int compute(self):
        return 2

cdef class ChildExcMinus1Raise(mod_a.BaseExcMinus1):
    # Inherits except -1; raises — exception must propagate to Cython callers.
    cpdef int compute(self):
        raise ValueError("ChildExcMinus1Raise raised")

cdef class ChildExcStarRaise(mod_a.BaseExcStar):
    # Inherits except *; raises — exception must propagate.
    cpdef int compute(self):
        raise ValueError("ChildExcStarRaise raised")

######## mod_c.pyx ########
# cython: language_level=3
# Consumer module: statically typed calls through base types from mod_a.
cimport mod_a
import mod_b

def call_noexcept_static():
    cdef mod_a.BaseNoexcept b = mod_b.ChildNoexcept()
    return b.compute()

def call_exc_minus1_raise_static():
    """Statically dispatches through BaseExcMinus1; exception must propagate."""
    cdef mod_a.BaseExcMinus1 b = mod_b.ChildExcMinus1Raise()
    return b.compute()

def call_exc_star_raise_static():
    """Statically dispatches through BaseExcStar; exception must propagate."""
    cdef mod_a.BaseExcStar b = mod_b.ChildExcStarRaise()
    return b.compute()

######## runner.py ########
import sys
import mod_a, mod_b, mod_c

def test():
    # 1. noexcept: returns correctly
    assert mod_c.call_noexcept_static() == 2, "noexcept static call failed"

    # 2. except -1 inherited, static Cython dispatch, override raises
    try:
        mod_c.call_exc_minus1_raise_static()
        assert False, "should have raised"
    except ValueError as e:
        assert str(e) == "ChildExcMinus1Raise raised", str(e)

    # 3. except * inherited, static Cython dispatch, override raises
    try:
        mod_c.call_exc_star_raise_static()
        assert False, "should have raised"
    except ValueError as e:
        assert str(e) == "ChildExcStarRaise raised", str(e)

    # 4. except -1 inherited, Python-level call (through __pyx_pw_ wrapper)
    obj = mod_b.ChildExcMinus1Raise()
    try:
        obj.compute()
        assert False, "should have raised"
    except ValueError as e:
        assert str(e) == "ChildExcMinus1Raise raised", str(e)

    # 5. Python subclass of cross-module base: override raises, called via Python
    class PySub(mod_a.BaseExcMinus1):
        def compute(self):
            raise RuntimeError("Python subclass raised")

    try:
        PySub().compute()
        assert False, "should have raised"
    except RuntimeError as e:
        assert str(e) == "Python subclass raised", str(e)

    # 6. Python subclass called via Cython static dispatch (OverrideCheckNode path)
    result_ok = mod_c.call_exc_minus1_raise_static.__doc__  # just confirm module loaded

    print("all cross-module exc spec tests: OK")

test()
