# mode: run

"""
PYTHON setup.py build_ext --inplace
PYTHON -c "import runner"
"""

######## setup.py ########

from Cython.Build.Dependencies import cythonize
import Cython.Compiler.Options
from distutils.core import setup

Cython.Compiler.Options.cimport_from_pyx = True

setup(
    ext_modules=cythonize([
        "py_enum.pyx",
        "consume_pyx_enum.pyx",
        "consume_py_enum.py",
    ]),
)

######## py_enum.pyx ########

from enum import Enum
from enum import IntEnum
from cython import cclass

@cclass
class PyEnum(Enum):
    RED = 1
    GREEN = 2

@cclass
class PyEnumInt(IntEnum):
    FIRST = 10
    SECOND = 20

@cclass
class PyEnumStr(Enum):
    RED = "red"
    GREEN = "green"

######## consume_pyx_enum.pyx ########

import cython
from py_enum import PyEnum, PyEnumInt, PyEnumStr
from cython.cimports.py_enum import PyEnum, PyEnumInt, PyEnumStr

@cython.ccall
def is_green(value: PyEnum) -> cython.bint:
    return value == PyEnum.GREEN

assert list(PyEnum) == [PyEnum.RED, PyEnum.GREEN], list(PyEnum)
assert is_green(PyEnum.GREEN)
assert list(PyEnumInt) == [PyEnumInt.FIRST, PyEnumInt.SECOND], list(PyEnumInt)
assert list(PyEnumStr) == [PyEnumStr.RED, PyEnumStr.GREEN], list(PyEnumStr)

######## consume_py_enum.py ########

import cython
from py_enum import PyEnum, PyEnumInt, PyEnumStr
from cython.cimports.py_enum import PyEnum, PyEnumInt, PyEnumStr

@cython.ccall
def is_green(value: PyEnum) -> cython.bint:
    return value == PyEnum.GREEN

assert list(PyEnum) == [PyEnum.RED, PyEnum.GREEN], list(PyEnum)
assert is_green(PyEnum.GREEN)
assert list(PyEnumInt) == [PyEnumInt.FIRST, PyEnumInt.SECOND], list(PyEnumInt)
assert list(PyEnumStr) == [PyEnumStr.RED, PyEnumStr.GREEN], list(PyEnumStr)

######## runner.py ########

import consume_pyx_enum
import consume_py_enum
